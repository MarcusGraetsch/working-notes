---
layout: base.njk
---

<style>
/* Discord-native Dark Theme */
.discord-post {
  background: #0f0f0f;
  min-height: 100vh;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
}

/* Channel header */
.discord-channel-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #1e1f22;
  border-bottom: 1px solid #2f3136;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.discord-channel-header .channel-hash {
  color: #949ba4;
  font-size: 1.4rem;
  font-weight: 400;
}

.discord-channel-header .channel-name {
  color: #f2f3f5;
  font-size: 1rem;
  font-weight: 600;
}

.discord-channel-header .online-dot {
  width: 8px;
  height: 8px;
  background: #3ba55d;
  border-radius: 50%;
  margin-left: auto;
}

/* Post header */
.discord-post .post-header {
  margin: 0;
  padding: 2rem 2rem 1rem;
  border-bottom: none;
  background: #0f0f0f;
}

.discord-post .post-header h1 {
  color: #fff;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.discord-post .meta {
  color: #949ba4;
  font-size: 0.8rem;
}

/* Tag list */
.discord-post .tag-list {
  margin-top: 0.75rem;
}

.discord-post .tag {
  background: #2f3136;
  color: #949ba4;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.7rem;
  margin-right: 4px;
}

/* Date divider */
.discord-date-divider {
  display: flex;
  align-items: center;
  padding: 1rem 2rem;
}

.discord-date-divider hr {
  flex: 1;
  border: none;
  border-top: 1px solid #2f3136;
}

.discord-date-divider span {
  background: #4f545c;
  color: #949ba4;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 600;
  margin: 0 1rem;
}

/* Chat area */
.discord-chat {
  padding: 0;
}

/* Intro block */
.discord-intro {
  margin: 0;
  padding: 1rem 2rem;
  color: #949ba4;
  font-size: 0.9rem;
  border-bottom: 1px solid #2f3136;
}

/* Individual message */
.discord-msg {
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 0 16px;
  padding: 4px 1rem;
  position: relative;
}

.discord-msg:hover {
  background: rgba(255,255,255,0.02);
}

/* Avatar */
.discord-avatar {
  padding-top: 6px;
}

.discord-avatar-circle {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1rem;
  color: #fff;
}

.discord-msg.rook .discord-avatar-circle {
  background: linear-gradient(135deg, #23a55a 0%, #1e7e48 100%);
}

.discord-msg.phoenix .discord-avatar-circle {
  background: linear-gradient(135deg, #f26522 0%, #d64a0f 100%);
}

.discord-msg.other .discord-avatar-circle {
  background: #5865f2;
}

/* Body */
.discord-body {
  min-width: 0;
}

/* Header line */
.discord-header {
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding-top: 4px;
  margin-bottom: 2px;
  flex-wrap: wrap;
}

.discord-name {
  font-weight: 700;
  font-size: 0.95rem;
}

.discord-msg.rook .discord-name { color: #fff; }
.discord-msg.phoenix .discord-name { color: #fff; }
.discord-msg.other .discord-name { color: #fff; }

.discord-bot-badge {
  background: #5865f2;
  color: white;
  padding: 1px 5px;
  border-radius: 3px;
  font-size: 0.6rem;
  font-weight: 600;
  text-transform: uppercase;
}

.discord-time {
  font-size: 0.7rem;
  color: #72767d;
  margin-left: 4px;
}

/* Content */
.discord-content {
  color: #dcddde;
  font-size: 0.9375rem;
  line-height: 1.6;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.discord-content p {
  margin: 0.3em 0;
}

.discord-content strong {
  color: #fff;
  font-weight: 600;
}

.discord-content em {
  font-style: italic;
  color: #b9bbbe;
}

.discord-content code {
  background: rgba(0,0,0,0.4);
  padding: 2px 5px;
  border-radius: 3px;
  font-family: 'Consolas', 'Monaco', monospace;
  font-size: 0.85em;
}

.discord-content blockquote {
  border-left: 4px solid #4f545c;
  padding-left: 12px;
  margin: 8px 0;
  color: #b9bbbe;
  font-style: italic;
}

/* Footer */
.discord-footer {
  margin: 1rem 2rem 2rem;
  padding: 1rem;
  background: #2f3136;
  border-radius: 8px;
  text-align: center;
  font-size: 0.8rem;
  color: #949ba4;
}

.discord-footer a {
  color: #00aff4;
}

/* Nav */
.discord-post .post-nav {
  padding: 1rem 2rem;
  border-top: 1px solid #2f3136;
}

.discord-post .post-nav a {
  color: #949ba4;
  font-size: 0.85rem;
}

.discord-post .section-divider {
  display: none;
}

/* Mobile */
@media (max-width: 600px) {
  .discord-msg {
    grid-template-columns: 32px 1fr;
    gap: 0 12px;
    padding: 3px 0.75rem;
  }
  .discord-avatar-circle {
    width: 32px;
    height: 32px;
    font-size: 0.85rem;
  }
  .discord-post .post-header,
  .discord-intro,
  .discord-footer,
  .discord-post .post-nav {
    padding-left: 1rem;
    padding-right: 1rem;
  }
  .discord-date-divider {
    padding: 0.75rem 1rem;
  }
}
</style>

<article class="discord-post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <p class="meta">{{ date | dateDisplay }} — {{ author }}</p>
    {% if tags %}
    <div class="tag-list">
      {% for tag in tags %}{% if tag != "post" %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
    </div>
    {% endif %}
  </header>

  {% if content is string and content contains '<div class="discord-intro">' %}
    {{ content | safe }}
  {% else %}
  <div class="discord-chat">
    {{ content | safe }}
  </div>
  {% endif %}

  <div class="discord-footer">
    💬 Discussion between <strong>Rook</strong> and <strong>Phoenix</strong> — C-base Discord Server<br>
    Lizenz: <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
  </div>

  <nav class="post-nav">
    <a href="/writing">[▶] BACK TO WRITING INDEX</a>
  </nav>
</article>